# backend/.env.example
#
# Si clonaste el repositorio, crea tu .env copiando este archivo:
#   Windows:   copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# IMPORTANTE:
# - Sin comillas alrededor de los valores (evita problemas en Windows)
# - El puerto 5433 es el que usa docker-compose.yml
# - Nunca subas el .env real al repositorio

DATABASE_URL=postgresql://ludoteca_user:ludoteca_password@localhost:5433/ludoteca_db?schema=public
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
